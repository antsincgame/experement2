{
  "name": "experement2",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "npx concurrently -n agent,expo -c cyan,magenta \"cd agent && npm run dev\" \"expo start --web\"",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:web": "playwright test -c playwright.e2e.config.ts",
    "test:agent": "npm --prefix agent run test",
    "typecheck:agent": "npm --prefix agent run typecheck",
    "check": "npm run typecheck && npm run typecheck:agent && npm run lint && npm run test && npm run test:agent"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "react-syntax-highlighter": "^16.1.1",
    "tailwindcss": "^3.4",
    "zod": "^4.3.6",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "~19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  },
  "private": true
}
