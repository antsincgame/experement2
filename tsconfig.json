// Narrows root TypeScript checks to the Expo app so backend and generated workspace code stay isolated.
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "agent",
    "workspace",
    "node_modules",
    ".expo"
  ]
}
