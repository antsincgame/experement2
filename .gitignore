# Ignores local dependency trees, build output, and E2E/test artifacts so CI/test runs do not pollute the repo status.
node_modules/
agent/node_modules/
agent/dist/
.expo/
test-results/
playwright-report/
workspace/e2e-existing-project/
workspace/vitest-*/
# Regenerated at runtime by initTemplateCache (node_modules already ignored above)
workspace/template_cache/src/
tools/e2e-results.json
e2e/*.json
e2e/*.md
.vite/
# Semantic RAG embedding cache + captured error->fix pairs (regenerated at runtime)
agent/.rag/
