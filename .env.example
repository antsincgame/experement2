# App Factory Configuration for LM Studio-only local development

# LM Studio server URL
LM_STUDIO_URL=http://localhost:1234

# Comma-separated extra hosts allowed for the model server (SSRF guard).
# Loopback and the LM_STUDIO_URL host are always allowed; set this only if the
# UI must reach a model server on another machine, e.g. 192.168.1.50
# LM_STUDIO_ALLOWED_HOSTS=

# Agent server port
AGENT_PORT=3100

# Agent bind host. Defaults to 127.0.0.1 (local-only — the trust boundary is THIS
# machine; the agent runs the LLM, writes files, and spawns Metro with no auth).
# Only change this to bind to a LAN/all-interfaces address if you ALSO set
# AGENT_LOCAL_TOKEN — otherwise any device on the network can drive the agent.
# AGENT_HOST=127.0.0.1

# Optional shared secret — when set, HTTP + WebSocket require this token.
# Required if you bind AGENT_HOST to anything other than loopback.
# AGENT_LOCAL_TOKEN=change-me
# EXPO_PUBLIC_AGENT_TOKEN=change-me
